rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Función de Ayuda ---
    // Esta función comprueba si el usuario que hace la solicitud
    // tiene un estado de 'approved' o 'admin' en la colección 'users'.
    function isApproved() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.data.status == 'approved' || userDoc.data.status == 'admin';
    }

    // --- Regla 1: Colección 'users' ---
    // Un usuario recién registrado puede crear su propio documento con status 'pending'.
    // Solo puede leer su propio documento. No puede modificar ni eliminar.
    match /users/{userId} {
      allow read: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId;
      allow update, delete: if false;
    }

    // --- Regla 2: Colección 'registros' ---
    match /registros/{docId} {
      allow read, write: if isApproved();
    }

    // --- Regla 3: Colección 'equipos' ---
    match /equipos/{docId} {
      allow read, write: if isApproved();
    }

    // --- Regla 4: Colección 'sintomas_globales' ---
    match /sintomas_globales/{docId} {
      allow read, write: if isApproved();
    }
  }
}
